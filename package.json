												"-is:wip OR owner:self",
												"owner:self OR reviewer:self OR cc:self"
											]
										}
									]
								}
							}
						}
					},
					"default": [
						{
							"title": "Dashboard",
							"panels": [
								{
									"title": "Your Turn",
									"refreshInterval": 300,
